---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const latestPost = sortedPosts[0];

// Send visitors straight to the latest post. If there are no posts yet,
// fall back to the posts listing.
const target = latestPost
  ? getPostUrl(latestPost.id, latestPost.filePath, locale)
  : getRelativeLocaleUrl(locale, "posts");

const canonical = new URL(target, Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang={config.site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonical} />
    <title>Redirecting…</title>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <a href={target}>Continue to the latest post</a>
  </body>
</html>
